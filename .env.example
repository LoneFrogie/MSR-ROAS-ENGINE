# ─── ROAS Engine Configuration ───
# Copy this to .env and fill in your credentials.

# App
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://roas:changeme@localhost:5432/roas_engine
REDIS_URL=redis://localhost:6379/0

# ─── Google Ads ───
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_CUSTOMER_ID=1234567890
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=  # Only for MCC accounts

# ─── Meta (Facebook/Instagram) Ads ───
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret
META_ACCESS_TOKEN=your-long-lived-access-token
META_AD_ACCOUNT_ID=your-ad-account-id
# META_PIXEL_ID=your-pixel-id

# ─── Google Search Console ───
GSC_CREDENTIALS_JSON=/path/to/service-account.json
GSC_SITE_URL=https://brand.com

# ─── Brand ───
BRAND_DOMAIN=brand.com
BRAND_SITEMAP_URL=https://brand.com/sitemap.xml

# ─── Optimization ───
OPTIMIZATION_MODE=balanced   # aggressive | balanced | conservative
TARGET_ROAS=4.0
MIN_ROAS_THRESHOLD=1.5
MAX_DAILY_BUDGET_CHANGE_PCT=0.20
MAX_BID_CHANGE_PCT=0.15
CONFIDENCE_THRESHOLD=0.75
LOOKBACK_DAYS=14
MAX_TOTAL_DAILY_BUDGET=10000
MAX_SINGLE_CAMPAIGN_BUDGET=2000

# ─── Guardrails ───
PAUSE_ON_ANOMALY=true
EMERGENCY_STOP_ROAS_BELOW=0.5

# ─── Scheduler ───
OPTIMIZATION_CYCLE_MINUTES=60
SEO_AUDIT_INTERVAL_HOURS=24
BUDGET_REALLOCATION_FREQUENCY_HOURS=6
REPORT_GENERATION_HOUR=8

# ─── Notifications ───
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# EMAIL_NOTIFICATIONS=you@brand.com,team@brand.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=alerts@brand.com
# SMTP_PASSWORD=your-app-password
